# Copy to `server/.env` (recommended) or repo-root `.env`.
# Docker Compose reads these when run from `server/` (see server/docker-compose.yml).

POSTGRES_DB=woleh
POSTGRES_USER=woleh
POSTGRES_PASSWORD=woleh
POSTGRES_PORT=5432

# Optional: point Spring Boot at Compose Postgres (defaults already match localhost:5432).
# DATABASE_URL=jdbc:postgresql://localhost:5432/woleh
# DATABASE_USER=woleh
# DATABASE_PASSWORD=woleh

# If the JVM working directory is the repo root (not `server/`), set:
# DOCKER_COMPOSE_FILE=server/docker-compose.yml
