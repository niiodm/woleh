# Copy to `.env` in this directory (never commit `.env`).
# Docker Compose reads `.env` from this directory for variable substitution in `docker-compose.yml`.
# deploy.sh does not shell-source `.env` (Compose allows characters that bash would treat as syntax).

POSTGRES_DB=woleh
POSTGRES_USER=woleh
# Use a long random password in real staging.
POSTGRES_PASSWORD=change-me

# HS256 signing key — use a long random secret (32+ bytes), not a placeholder.
JWT_SECRET=change-me-min-256-bits-for-hs256

# Public API origin for payment stub checkout URLs (POST /subscription/checkout → checkoutUrl).
# Override if staging uses a different host than Caddy’s TLS name.
# PAYMENT_BASE_URL=https://woleh.okaidarkomorgan.com

# Optional: comma-separated Ant-style patterns (see application.yml).
# CORS_ALLOWED_ORIGIN_PATTERNS=https://woleh.okaidarkomorgan.com,http://localhost:*,http://127.0.0.1:*

# Optional Actuator detail level (staging defaults to when-authorized via application-staging.yml).
# HEALTH_SHOW_DETAILS=when-authorized

# Optional Sentry (API errors). Compose passes env into the API container — see server/README.md.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_TRACES_SAMPLE_RATE=0.2

# SMS / OTP — default is mock: API logs "StubSmsAdapter ... OTP send skipped" and does not send SMS.
# For real delivery (NALO — https://sms.nalosolutions.com), set:
#   SMS_PROVIDER=nalo
#   NALO_SMS_API_KEY=<your NALO API key>
# Optional: NALO_SMS_SENDER_ID (default Woleh), NALO_SMS_API_URL if NALO changes the endpoint.
# SMS_PROVIDER=mock
# NALO_SMS_API_KEY=
# NALO_SMS_SENDER_ID=Woleh

# Prometheus scrape auth (HTTP Basic for /actuator/prometheus on port 8081). Must match deploy/staging/prometheus.yml basic_auth.
# Defaults in docker-compose.yml are prometheus / changeme — override in production-like staging.
# PROMETHEUS_SCRAPE_USER=prometheus
# PROMETHEUS_SCRAPE_PASSWORD=changeme

# Grafana (loopback:3000 on the host). Override the default password.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me
