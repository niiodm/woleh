# Copy to `.env` in this directory (never commit `.env`).
# Docker Compose reads `.env` from this directory for variable substitution in `docker-compose.yml`.
# deploy.sh does not shell-source `.env` (Compose allows characters that bash would treat as syntax).

POSTGRES_DB=woleh
POSTGRES_USER=woleh
# Use a long random password in real staging.
POSTGRES_PASSWORD=change-me

# HS256 signing key — use a long random secret (32+ bytes), not a placeholder.
JWT_SECRET=change-me-min-256-bits-for-hs256

# Optional: comma-separated Ant-style patterns (see application.yml).
# CORS_ALLOWED_ORIGIN_PATTERNS=https://woleh.okaidarkomorgan.com,http://localhost:*,http://127.0.0.1:*

# Optional Actuator detail level (staging defaults to when-authorized via application-staging.yml).
# HEALTH_SHOW_DETAILS=when-authorized

# Optional: real SMS in staging (defaults in application.yml use mock if unset).
# SMS_PROVIDER=mock
# NALO_SMS_API_KEY=
# NALO_SMS_SENDER_ID=Woleh
