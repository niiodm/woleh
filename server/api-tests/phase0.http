### Phase 0 — manual QA collection
# Covers the full happy-path flow: health → send-otp → verify-otp → GET /me → PATCH profile.
#
# IntelliJ HTTP Client: select the "dev" environment from http-client.env.json.
# VS Code REST Client: set @baseUrl and @phone manually below.
#
# How to run the happy path end-to-end:
#   1. Start server: cd server && ./gradlew bootRun  (or --spring.profiles.active=dev for H2)
#   2. Run "Health" — expect UP.
#   3. Run "Send OTP".  Copy the OTP from the console [DEV] log (woleh.otp.dev-log-otp=true in dev profile).
#   4. Run "Verify OTP" with the copied OTP.  Copy accessToken from the response.
#   5. Paste the token into @token below, then run "GET /me" and "PATCH /me/profile".

@baseUrl = {{baseUrl}}
@phone   = {{phone}}
@token   = PASTE_ACCESS_TOKEN_HERE

###############################################################################
# 0. Health
###############################################################################

### Health — liveness (no auth required)
GET {{baseUrl}}/actuator/health
Accept: application/json

### Health — liveness probe
GET {{baseUrl}}/actuator/health/liveness

### Health — readiness probe
GET {{baseUrl}}/actuator/health/readiness

###############################################################################
# 1. Authentication — send OTP
###############################################################################

### Send OTP — happy path
POST {{baseUrl}}/api/v1/auth/send-otp
Content-Type: application/json

{
  "phoneE164": "{{phone}}"
}

### Send OTP — invalid number (expects 400 VALIDATION_ERROR)
POST {{baseUrl}}/api/v1/auth/send-otp
Content-Type: application/json

{
  "phoneE164": "07911123456"
}

### Send OTP — rate limit smoke (run this request 4× for the same number; 4th should return 429 RATE_LIMITED)
POST {{baseUrl}}/api/v1/auth/send-otp
Content-Type: application/json

{
  "phoneE164": "{{phone}}"
}

###############################################################################
# 2. Authentication — verify OTP  (replace 123456 with OTP from [DEV] console log)
###############################################################################

### Verify OTP — happy path → copy accessToken from response into @token above
POST {{baseUrl}}/api/v1/auth/verify-otp
Content-Type: application/json

{
  "phoneE164": "{{phone}}",
  "otp": "123456"
}

### Verify OTP — wrong code (expects 400 INVALID_OTP)
POST {{baseUrl}}/api/v1/auth/verify-otp
Content-Type: application/json

{
  "phoneE164": "{{phone}}",
  "otp": "000000"
}

### Verify OTP — invalid format (expects 400 VALIDATION_ERROR)
POST {{baseUrl}}/api/v1/auth/verify-otp
Content-Type: application/json

{
  "phoneE164": "{{phone}}",
  "otp": "abc"
}

###############################################################################
# 3. Profile — GET /me
###############################################################################

### GET /me — authenticated (expects profile + free-tier entitlements)
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{token}}

### GET /me — no token (expects 401 UNAUTHORIZED)
GET {{baseUrl}}/api/v1/me

###############################################################################
# 4. Profile — PATCH /me/profile
###############################################################################

### PATCH /me/profile — set display name
PATCH {{baseUrl}}/api/v1/me/profile
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "displayName": "Ama Owusu"
}

### PATCH /me/profile — confirm name persisted (re-run GET /me)
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{token}}

### PATCH /me/profile — reject immutable field (expects 400 VALIDATION_ERROR)
PATCH {{baseUrl}}/api/v1/me/profile
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "displayName": "Ama",
  "phoneE164": "+233241234567"
}
