<?xml version="1.0" encoding="UTF-8"?>
<configuration>

	<!-- Development / CI / default: human-readable lines with correlation IDs -->
	<springProfile name="!prod">
		<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
			<encoder>
				<pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %-5level [%X{requestId:-no-rid}] [userId:%X{userId:-anon}] %logger{36} - %msg%n</pattern>
			</encoder>
		</appender>
	</springProfile>

	<!--
		Production: structured JSON — add logstash-logback-encoder to build.gradle
		and replace the encoder class with:
		    net.logstash.logback.encoder.LogstashEncoder
		The MDC keys (requestId, userId) will appear as top-level JSON fields,
		making them queryable in any log aggregator (Cloud Logging, Loki, Datadog…).
	-->
	<springProfile name="prod">
		<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
			<encoder>
				<pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %-5level [%X{requestId:-no-rid}] [userId:%X{userId:-anon}] %logger{36} - %msg%n</pattern>
			</encoder>
		</appender>
	</springProfile>

	<!-- Suppress noisy framework INFO traffic; keep WARN for Hibernate / Spring -->
	<logger name="org.hibernate.SQL" level="WARN"/>
	<logger name="org.springframework.web" level="WARN"/>
	<logger name="org.springframework.security" level="WARN"/>

	<root level="INFO">
		<appender-ref ref="CONSOLE"/>
	</root>

</configuration>
